# ────────────────────────────────────────────────────────────────────────────
# LATTICE environment variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# ────────────────────────────────────────────────────────────────────────────

# ─── Database (Supabase Postgres connection string) ───────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ─── Real-time CRDT sync (y-websocket server) ─────────────────────────────
# Public — exposed to the browser. Use ws:// in dev, wss:// in production.
NEXT_PUBLIC_WS_URL=ws://localhost:1234

# ─── Pexels (hero / section photos — Design Law 11) ────────────────────────
# Get a free key at https://www.pexels.com/api/ (200 req/hr).
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Supabase (auth + site metadata storage) ──────────────────────────────
# These two are NEXT_PUBLIC_* because the browser Supabase client needs
# them. Do NOT mark the JWT secret as public.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only — used by @lattice/realtime to verify WS handshakes.
# Find it in: Supabase dashboard → Project Settings → API → JWT Secret.
# Must be ≥ 32 chars (Supabase's default is 64 hex).
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_at_least_32_chars_long

# ─── Realtime server (Task 1.5) ───────────────────────────────────────────
# Comma-separated list of origins allowed to open WS connections.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Port the realtime server binds to. Matches docker-compose.yml.
PORT=1234
# Bind host. 0.0.0.0 inside Docker, 127.0.0.1 if you want to lock down
# the dev server.
HOST=0.0.0.0

# ─── Stripe (headless commerce — Skill 4) ──────────────────────────────────
# Server-side only. Never expose with a NEXT_PUBLIC_ prefix.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
