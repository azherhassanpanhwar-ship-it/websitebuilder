{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "LATTICE Theme #1 — Fine Dining. Warm neutrals + deep gold accent (Design Law 1, Restaurants / Fine Dining). Display = Cormorant Garamond, Body = Inter (Design Law 2, Luxury / Fine Dining pairing). Sharp radius (0–2px) per Design Law 7. Subtle shadow per Design Law 8. Subtle animation per Design Law 6. All literal atomic values live here; components consume `var(--*)` references only (Skill 2).",
  "$metadata": {
    "system": "LATTICE",
    "version": "1.0.0",
    "theme": {
      "slug": "fine-dining",
      "name": "Fine Dining",
      "category": "restaurants",
      "subcategory": "fine-dining"
    },
    "design_laws": [
      "Design Law 1 — Restaurants / Fine Dining (warm neutrals + deep gold)",
      "Design Law 2 — Luxury / Fine Dining typography (Cormorant Garamond + Inter)",
      "Design Law 4 — full-bleed-image hero pattern",
      "Design Law 6 — subtle animation (no continuous loops)",
      "Design Law 7 — sharp radius (0–2px)",
      "Design Law 8 — subtle shadow (xs–md)"
    ],
    "see": [
      "CLAUDE.md §6.5 God Mode Design Workflow",
      "CLAUDE.md §6.5 Design Laws 1–8",
      "docs/LATTICE_Implementation_Plan_v3.0.md §2.4 (Category 1, Theme #1)"
    ]
  },

  "color": {
    "primary": {
      "50": {
        "$value": "#FAF6E8",
        "$type": "color",
        "$description": "Very pale cream — light surface tint"
      },
      "100": {
        "$value": "#F5EFD8",
        "$type": "color",
        "$description": "Pale cream — hover surface"
      },
      "200": { "$value": "#E8D8A8", "$type": "color", "$description": "Light gold tint" },
      "300": { "$value": "#D4BC7A", "$type": "color", "$description": "Soft gold" },
      "500": {
        "$value": "#C9A84C",
        "$type": "color",
        "$description": "Deep gold — the brand color, used for buttons and accents"
      },
      "700": {
        "$value": "#9E8135",
        "$type": "color",
        "$description": "Deep gold pressed / dark accent"
      },
      "900": {
        "$value": "#6B5722",
        "$type": "color",
        "$description": "Dark gold — text on light surface"
      }
    },
    "onPrimary": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Foreground on primary-500 (deep gold)"
    },

    "accent": {
      "$value": "#722F37",
      "$type": "color",
      "$description": "Burgundy — Design Law 1 secondary accent for fine dining"
    },
    "onAccent": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Foreground on accent (burgundy)"
    },

    "surface": {
      "$value": "#FAF6EE",
      "$type": "color",
      "$description": "Warm white / cream — page background"
    },
    "surfaceAlt": {
      "$value": "#F0E8D8",
      "$type": "color",
      "$description": "Slightly deeper cream — cards, panels, sidebars"
    },
    "surfaceDark": {
      "$value": "#2B2419",
      "$type": "color",
      "$description": "Dark warm brown — footer, inverse blocks"
    },

    "text": {
      "$value": "#1F1A12",
      "$type": "color",
      "$description": "Deep brown-black — body text"
    },
    "textMuted": {
      "$value": "#6B5F4D",
      "$type": "color",
      "$description": "Warm gray — helper / caption text"
    },

    "border": {
      "$value": "#D4C8B0",
      "$type": "color",
      "$description": "Hairline divider / border"
    },
    "focusRing": {
      "$value": "#C9A84C",
      "$type": "color",
      "$description": "WCAG 3:1 focus outline (deep gold)"
    },

    "error": {
      "$value": "#A04545",
      "$type": "color",
      "$description": "Form / commerce error state"
    },
    "success": {
      "$value": "#5C7848",
      "$type": "color",
      "$description": "Form / commerce success state"
    },

    "heroOverlayFrom": {
      "$value": "rgba(15, 10, 5, 0)",
      "$type": "color",
      "$description": "Top of full-bleed hero gradient overlay (transparent)"
    },
    "heroOverlayTo": {
      "$value": "rgba(15, 10, 5, 0.78)",
      "$type": "color",
      "$description": "Bottom of full-bleed hero gradient overlay (deep brown-black 78%)"
    }
  },

  "font": {
    "display": {
      "$value": "'Cormorant Garamond', 'EB Garamond', Georgia, serif",
      "$type": "fontFamily",
      "$description": "Display / heading family — Design Law 2 Luxury serif"
    },
    "body": {
      "$value": "'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "$type": "fontFamily",
      "$description": "Body / UI family — Design Law 2 clean sans"
    },
    "mono": {
      "$value": "'JetBrains Mono', 'SF Mono', Menlo, monospace",
      "$type": "fontFamily",
      "$description": "Monospace family for tabular data / code"
    }
  },

  "fontWeight": {
    "display": {
      "$value": "500",
      "$type": "fontWeight",
      "$description": "Cormorant Garamond @ 500 (regular) for display — per Design Law 2 'max tracking on headlines, weight 500 max'"
    },
    "bodyRegular": {
      "$value": "400",
      "$type": "fontWeight",
      "$description": "Inter regular for body copy"
    },
    "bodyMedium": {
      "$value": "500",
      "$type": "fontWeight",
      "$description": "Inter medium for buttons / labels"
    },
    "bodySemibold": {
      "$value": "600",
      "$type": "fontWeight",
      "$description": "Inter semibold for emphasis"
    }
  },

  "letterSpacing": {
    "display": {
      "$value": "0.005em",
      "$type": "dimension",
      "$description": "Cormorant Garamond headlines — slight positive tracking per Design Law 2 'max tracking on headlines'"
    },
    "body": {
      "$value": "0",
      "$type": "dimension",
      "$description": "Inter body — default tracking"
    },
    "eyebrow": {
      "$value": "0.18em",
      "$type": "dimension",
      "$description": "Uppercase eyebrow text — wide tracking for luxury feel"
    }
  },

  "lineHeight": {
    "display": {
      "$value": "1.1",
      "$type": "number",
      "$description": "Tight headline leading for Cormorant Garamond"
    },
    "subhead": { "$value": "1.25", "$type": "number", "$description": "Subhead leading" },
    "body": {
      "$value": "1.65",
      "$type": "number",
      "$description": "Body copy leading — within Design Law 2 1.6–1.75 range"
    },
    "caption": { "$value": "1.4", "$type": "number", "$description": "Caption / helper text" }
  },

  "space": {
    "0": { "$value": "0", "$type": "dimension", "$description": "Reset" },
    "1": { "$value": "4px", "$type": "dimension", "$description": "Micro gaps, icon padding" },
    "2": { "$value": "8px", "$type": "dimension", "$description": "Tight component gaps" },
    "3": { "$value": "12px", "$type": "dimension", "$description": "Small component gaps" },
    "4": { "$value": "16px", "$type": "dimension", "$description": "Base unit" },
    "5": { "$value": "24px", "$type": "dimension", "$description": "Comfortable gaps" },
    "6": { "$value": "32px", "$type": "dimension", "$description": "Section sub-gaps" },
    "7": { "$value": "48px", "$type": "dimension", "$description": "Section padding mobile" },
    "8": { "$value": "64px", "$type": "dimension", "$description": "Section padding mobile" },
    "9": { "$value": "96px", "$type": "dimension", "$description": "Section padding desktop" },
    "10": { "$value": "128px", "$type": "dimension", "$description": "Hero vertical rhythm" },
    "11": { "$value": "160px", "$type": "dimension", "$description": "XL hero padding" }
  },

  "radius": {
    "none": {
      "$value": "0",
      "$type": "dimension",
      "$description": "Sharp corners (law firms, architecture, fine dining, editorial) — Design Law 7"
    },
    "xs": {
      "$value": "0",
      "$type": "dimension",
      "$description": "Sharp — Design Law 7 sharp variant"
    },
    "sm": {
      "$value": "1px",
      "$type": "dimension",
      "$description": "Inputs / small buttons — Design Law 7 sharp (0–2px)"
    },
    "md": {
      "$value": "2px",
      "$type": "dimension",
      "$description": "Cards / buttons — Design Law 7 sharp (0–2px)"
    },
    "lg": {
      "$value": "2px",
      "$type": "dimension",
      "$description": "Modals / panels — Design Law 7 sharp"
    },
    "xl": {
      "$value": "2px",
      "$type": "dimension",
      "$description": "Hero images / large cards — Design Law 7 sharp"
    },
    "2xl": { "$value": "2px", "$type": "dimension", "$description": "Design Law 7 sharp" },
    "full": {
      "$value": "9999px",
      "$type": "dimension",
      "$description": "Pills / avatars / toggles (preserved as the only exception — pill shapes need a circle)"
    }
  },

  "shadow": {
    "none": {
      "$value": "none",
      "$type": "shadow",
      "$description": "Flat (editorial, minimal SaaS) — Design Law 8"
    },
    "xs": {
      "$value": "0 1px 2px rgba(31, 26, 18, 0.05)",
      "$type": "shadow",
      "$description": "Hairline elevation — Design Law 8 subtle"
    },
    "sm": {
      "$value": "0 1px 3px rgba(31, 26, 18, 0.10), 0 1px 2px rgba(31, 26, 18, 0.06)",
      "$type": "shadow",
      "$description": "Subtle lift — Design Law 8 subtle (default card shadow)"
    },
    "md": {
      "$value": "0 4px 6px rgba(31, 26, 18, 0.07), 0 2px 4px rgba(31, 26, 18, 0.06)",
      "$type": "shadow",
      "$description": "Default card shadow — Design Law 8 subtle"
    },
    "lg": {
      "$value": "0 10px 15px rgba(31, 26, 18, 0.10), 0 4px 6px rgba(31, 26, 18, 0.05)",
      "$type": "shadow",
      "$description": "Hover lift — Design Law 8 subtle (max for fine dining)"
    },
    "xl": {
      "$value": "0 20px 25px rgba(31, 26, 18, 0.10), 0 10px 10px rgba(31, 26, 18, 0.04)",
      "$type": "shadow",
      "$description": "Modal / overlay"
    },
    "colored": {
      "$value": "0 8px 24px rgba(201, 168, 76, 0.25)",
      "$type": "shadow",
      "$description": "Colored halo — deep gold tint for primary buttons"
    },
    "inner": {
      "$value": "inset 0 2px 4px rgba(31, 26, 18, 0.06)",
      "$type": "shadow",
      "$description": "Pressed / inset"
    }
  },

  "duration": {
    "fast": {
      "$value": "150ms",
      "$type": "duration",
      "$description": "Micro feedback (button press) — Design Law 6"
    },
    "base": {
      "$value": "250ms",
      "$type": "duration",
      "$description": "Standard transitions (hover, focus) — Design Law 6"
    },
    "enter": {
      "$value": "400ms",
      "$type": "duration",
      "$description": "Elements entering viewport — Design Law 6 subtle"
    },
    "page": {
      "$value": "600ms",
      "$type": "duration",
      "$description": "Page-level transitions — Design Law 6"
    }
  },

  "easing": {
    "standard": {
      "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
      "$type": "cubicBezier",
      "$description": "Material standard — Design Law 6"
    },
    "decelerate": {
      "$value": "cubic-bezier(0, 0, 0.2, 1)",
      "$type": "cubicBezier",
      "$description": "Elements entering — Design Law 6"
    },
    "accelerate": {
      "$value": "cubic-bezier(0.4, 0, 1, 1)",
      "$type": "cubicBezier",
      "$description": "Elements exiting — Design Law 6"
    },
    "spring": {
      "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "$type": "cubicBezier",
      "$description": "Playful bounce — preserved for micro-interactions"
    }
  },

  "hero": {
    "minHeight": {
      "$value": "100vh",
      "$type": "dimension",
      "$description": "Full-bleed hero min height — Design Law 4"
    },
    "minHeightMobile": {
      "$value": "85vh",
      "$type": "dimension",
      "$description": "Slightly shorter on mobile to keep CTA visible"
    },
    "overlayFrom": {
      "$value": "{color.heroOverlayFrom.$value}",
      "$type": "color",
      "$description": "Top of gradient — transparent"
    },
    "overlayTo": {
      "$value": "{color.heroOverlayTo.$value}",
      "$type": "color",
      "$description": "Bottom of gradient — dark for text contrast"
    },
    "textPosition": {
      "$value": "bottom-left",
      "$type": "string",
      "$description": "Text alignment per Design Law 4 full-bleed-image"
    },
    "imagePosition": {
      "$value": "center",
      "$type": "string",
      "$description": "object-position — Design Law 4 'never center-crop on mobile' (use object-top on mobile via component-level override)"
    }
  },

  "css": {
    "$description": "The mapping from token name → CSS custom property. ThemeProvider emits these as :root rules. Components consume `var(--token-*)` only.",

    "color": {
      "--color-primary-50": { "$value": "{color.primary.50.$value}", "$type": "color" },
      "--color-primary-100": { "$value": "{color.primary.100.$value}", "$type": "color" },
      "--color-primary-200": { "$value": "{color.primary.200.$value}", "$type": "color" },
      "--color-primary-300": { "$value": "{color.primary.300.$value}", "$type": "color" },
      "--color-primary-500": { "$value": "{color.primary.500.$value}", "$type": "color" },
      "--color-primary-700": { "$value": "{color.primary.700.$value}", "$type": "color" },
      "--color-primary-900": { "$value": "{color.primary.900.$value}", "$type": "color" },
      "--color-on-primary": { "$value": "{color.onPrimary.$value}", "$type": "color" },

      "--color-accent": { "$value": "{color.accent.$value}", "$type": "color" },
      "--color-on-accent": { "$value": "{color.onAccent.$value}", "$type": "color" },

      "--color-surface": { "$value": "{color.surface.$value}", "$type": "color" },
      "--color-surface-alt": { "$value": "{color.surfaceAlt.$value}", "$type": "color" },
      "--color-surface-dark": { "$value": "{color.surfaceDark.$value}", "$type": "color" },

      "--color-text": { "$value": "{color.text.$value}", "$type": "color" },
      "--color-text-muted": { "$value": "{color.textMuted.$value}", "$type": "color" },

      "--color-border": { "$value": "{color.border.$value}", "$type": "color" },
      "--color-focus-ring": { "$value": "{color.focusRing.$value}", "$type": "color" },

      "--color-error": { "$value": "{color.error.$value}", "$type": "color" },
      "--color-success": { "$value": "{color.success.$value}", "$type": "color" }
    },

    "font": {
      "--font-display": { "$value": "{font.display.$value}", "$type": "fontFamily" },
      "--font-body": { "$value": "{font.body.$value}", "$type": "fontFamily" },
      "--font-mono": { "$value": "{font.mono.$value}", "$type": "fontFamily" }
    },

    "space": {
      "--space-0": { "$value": "{space.0.$value}", "$type": "dimension" },
      "--space-1": { "$value": "{space.1.$value}", "$type": "dimension" },
      "--space-2": { "$value": "{space.2.$value}", "$type": "dimension" },
      "--space-3": { "$value": "{space.3.$value}", "$type": "dimension" },
      "--space-4": { "$value": "{space.4.$value}", "$type": "dimension" },
      "--space-5": { "$value": "{space.5.$value}", "$type": "dimension" },
      "--space-6": { "$value": "{space.6.$value}", "$type": "dimension" },
      "--space-7": { "$value": "{space.7.$value}", "$type": "dimension" },
      "--space-8": { "$value": "{space.8.$value}", "$type": "dimension" },
      "--space-9": { "$value": "{space.9.$value}", "$type": "dimension" },
      "--space-10": { "$value": "{space.10.$value}", "$type": "dimension" },
      "--space-11": { "$value": "{space.11.$value}", "$type": "dimension" }
    },

    "radius": {
      "--radius-none": { "$value": "{radius.none.$value}", "$type": "dimension" },
      "--radius-xs": { "$value": "{radius.xs.$value}", "$type": "dimension" },
      "--radius-sm": { "$value": "{radius.sm.$value}", "$type": "dimension" },
      "--radius-md": { "$value": "{radius.md.$value}", "$type": "dimension" },
      "--radius-lg": { "$value": "{radius.lg.$value}", "$type": "dimension" },
      "--radius-xl": { "$value": "{radius.xl.$value}", "$type": "dimension" },
      "--radius-2xl": { "$value": "{radius.2xl.$value}", "$type": "dimension" },
      "--radius-full": { "$value": "{radius.full.$value}", "$type": "dimension" }
    },

    "shadow": {
      "--shadow-none": { "$value": "{shadow.none.$value}", "$type": "shadow" },
      "--shadow-xs": { "$value": "{shadow.xs.$value}", "$type": "shadow" },
      "--shadow-sm": { "$value": "{shadow.sm.$value}", "$type": "shadow" },
      "--shadow-md": { "$value": "{shadow.md.$value}", "$type": "shadow" },
      "--shadow-lg": { "$value": "{shadow.lg.$value}", "$type": "shadow" },
      "--shadow-xl": { "$value": "{shadow.xl.$value}", "$type": "shadow" },
      "--shadow-colored": { "$value": "{shadow.colored.$value}", "$type": "shadow" },
      "--shadow-inner": { "$value": "{shadow.inner.$value}", "$type": "shadow" }
    },

    "duration": {
      "--duration-fast": { "$value": "{duration.fast.$value}", "$type": "duration" },
      "--duration-base": { "$value": "{duration.base.$value}", "$type": "duration" },
      "--duration-enter": { "$value": "{duration.enter.$value}", "$type": "duration" },
      "--duration-page": { "$value": "{duration.page.$value}", "$type": "duration" }
    },

    "easing": {
      "--easing-standard": { "$value": "{easing.standard.$value}", "$type": "cubicBezier" },
      "--easing-decelerate": { "$value": "{easing.decelerate.$value}", "$type": "cubicBezier" },
      "--easing-accelerate": { "$value": "{easing.accelerate.$value}", "$type": "cubicBezier" },
      "--easing-spring": { "$value": "{easing.spring.$value}", "$type": "cubicBezier" }
    },

    "hero": {
      "--hero-overlay-from": { "$value": "{color.heroOverlayFrom.$value}", "$type": "color" },
      "--hero-overlay-to": { "$value": "{color.heroOverlayTo.$value}", "$type": "color" }
    },

    "fontWeight": {
      "--font-weight-display": { "$value": "{fontWeight.display.$value}", "$type": "fontWeight" },
      "--font-weight-body-regular": {
        "$value": "{fontWeight.bodyRegular.$value}",
        "$type": "fontWeight"
      },
      "--font-weight-body-medium": {
        "$value": "{fontWeight.bodyMedium.$value}",
        "$type": "fontWeight"
      },
      "--font-weight-body-semibold": {
        "$value": "{fontWeight.bodySemibold.$value}",
        "$type": "fontWeight"
      }
    },

    "lineHeight": {
      "--line-height-display": { "$value": "{lineHeight.display.$value}", "$type": "number" },
      "--line-height-subhead": { "$value": "{lineHeight.subhead.$value}", "$type": "number" },
      "--line-height-body": { "$value": "{lineHeight.body.$value}", "$type": "number" },
      "--line-height-caption": { "$value": "{lineHeight.caption.$value}", "$type": "number" }
    },

    "letterSpacing": {
      "--letter-spacing-display": {
        "$value": "{letterSpacing.display.$value}",
        "$type": "dimension"
      },
      "--letter-spacing-body": { "$value": "{letterSpacing.body.$value}", "$type": "dimension" },
      "--letter-spacing-eyebrow": {
        "$value": "{letterSpacing.eyebrow.$value}",
        "$type": "dimension"
      }
    }
  }
}
