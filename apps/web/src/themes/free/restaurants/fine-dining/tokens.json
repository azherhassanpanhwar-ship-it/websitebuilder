{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "LATTICE Theme #1 — Fine Dining (REVISED — dark + gold + Bodoni). Reference-driven UI/UX redesign. Dark surfaces (#131313 → #3a3939), saturated gold primary (#e9c176), Bodoni Moda display + Hanken Grotesk body, generous section-gap (120px), and reference typography scale. The content (chef, courses, address, hours) is unchanged from the previous version — only the visual system was rebuilt.",
  "$metadata": {
    "system": "LATTICE",
    "version": "2.0.0",
    "supersedes": "1.0.0",
    "theme": {
      "slug": "fine-dining",
      "name": "Fine Dining",
      "category": "restaurants",
      "subcategory": "fine-dining"
    },
    "design_laws": [
      "Design Law 1 — Restaurants / Fine Dining (warm neutrals + deep gold)",
      "Design Law 2 — Luxury typography (Bodoni Moda + Hanken Grotesk)",
      "Design Law 3 — Spacious density (luxury)",
      "Design Law 4 — Full-bleed-image hero pattern",
      "Design Law 5 — Sticky transparent header, mobile hamburger at md, 44px tap targets",
      "Design Law 6 — Subtle animation (no continuous loops)",
      "Design Law 7 — Sharp radius (0–2px)",
      "Design Law 8 — Subtle shadow (xs–md)",
      "Design Law 10 — Quality self-check pre-merge"
    ]
  },

  "color": {
    "primary": {
      "50": { "$value": "#FFFAEB", "$type": "color", "$description": "Pale gold tint" },
      "100": { "$value": "#FCEBC6", "$type": "color", "$description": "Light gold" },
      "200": { "$value": "#F6D894", "$type": "color", "$description": "Soft gold" },
      "300": { "$value": "#EFC479", "$type": "color", "$description": "Mid gold" },
      "500": {
        "$value": "#E9C176",
        "$type": "color",
        "$description": "Saturated gold — the brand color"
      },
      "700": {
        "$value": "#C5A059",
        "$type": "color",
        "$description": "Darker gold — hover/pressed"
      },
      "900": { "$value": "#775A19", "$type": "color", "$description": "Inverse primary" }
    },
    "onPrimary": { "$value": "#412D00", "$type": "color", "$description": "Text on primary gold" },

    "accent": {
      "$value": "#E9C176",
      "$type": "color",
      "$description": "Single accent for this theme"
    },
    "onAccent": { "$value": "#412D00", "$type": "color" },

    "surface": {
      "$value": "#131313",
      "$type": "color",
      "$description": "Page background — near-black"
    },
    "surfaceAlt": { "$value": "#1C1B1B", "$type": "color", "$description": "Cards, panels" },
    "surfaceCard": { "$value": "#201F1F", "$type": "color", "$description": "Bento card surface" },
    "surfaceHigh": { "$value": "#2A2A2A", "$type": "color", "$description": "Higher elevation" },
    "surfaceHighest": {
      "$value": "#353534",
      "$type": "color",
      "$description": "Highest elevation"
    },
    "surfaceDark": {
      "$value": "#0E0E0E",
      "$type": "color",
      "$description": "Deepest surface — footer"
    },
    "surfaceBright": { "$value": "#3A3939", "$type": "color", "$description": "Bright surface" },

    "text": { "$value": "#E5E2E1", "$type": "color", "$description": "Primary on-surface text" },
    "textMuted": { "$value": "#D1C5B4", "$type": "color", "$description": "Muted text" },
    "textFaint": { "$value": "#9A8F80", "$type": "color", "$description": "Faint text" },

    "border": { "$value": "#4E4639", "$type": "color", "$description": "Hairline divider" },
    "borderSubtle": { "$value": "#2A2A2A", "$type": "color", "$description": "Subtle border" },
    "focusRing": { "$value": "#E9C176", "$type": "color", "$description": "Focus ring" },

    "success": { "$value": "#5C7848", "$type": "color", "$description": "Success green (muted)" },
    "error": {
      "$value": "#A04545",
      "$type": "color",
      "$description": "Error red (muted, AA on dark surface)"
    },
    "heroOverlayFrom": {
      "$value": "rgba(14, 14, 14, 0.20)",
      "$type": "color",
      "$description": "Top of hero gradient"
    },
    "heroOverlayTo": {
      "$value": "rgba(14, 14, 14, 0.92)",
      "$type": "color",
      "$description": "Bottom of hero gradient"
    }
  },

  "font": {
    "display": {
      "$value": "'Bodoni Moda', 'Bodoni 72', Didot, Georgia, serif",
      "$type": "fontFamily",
      "$description": "Display / heading — Bodoni Moda (with italic). The reference's serif. Dramatic high-contrast strokes for luxury feel."
    },
    "body": {
      "$value": "'Hanken Grotesk', system-ui, -apple-system, 'Segoe UI', sans-serif",
      "$type": "fontFamily",
      "$description": "Body / UI — Hanken Grotesk (the reference's sans)"
    },
    "mono": { "$value": "'JetBrains Mono', 'SF Mono', Menlo, monospace", "$type": "fontFamily" }
  },

  "fontWeight": {
    "displayLight": {
      "$value": "400",
      "$type": "fontWeight",
      "$description": "Bodoni Moda regular for display"
    },
    "displayItalic": {
      "$value": "400",
      "$type": "fontWeight",
      "$description": "Bodoni Moda italic — used for pull-quotes"
    },
    "bodyRegular": { "$value": "400", "$type": "fontWeight" },
    "bodySemibold": {
      "$value": "600",
      "$type": "fontWeight",
      "$description": "Hanken Grotesk semibold for label-caps"
    }
  },

  "fontSize": {
    "displayLg": {
      "$value": "84px",
      "$type": "dimension",
      "$description": "Hero headline desktop"
    },
    "displayLgMobile": {
      "$value": "48px",
      "$type": "dimension",
      "$description": "Hero headline mobile"
    },
    "headlineXl": { "$value": "60px", "$type": "dimension", "$description": "Section headline" },
    "headlineLg": { "$value": "40px", "$type": "dimension", "$description": "Subsection headline" },
    "bodyLg": { "$value": "18px", "$type": "dimension", "$description": "Large body" },
    "bodyMd": { "$value": "16px", "$type": "dimension", "$description": "Body" },
    "labelCaps": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Uppercase eyebrow / label"
    }
  },

  "letterSpacing": {
    "display": {
      "$value": "-0.02em",
      "$type": "dimension",
      "$description": "Display headline — slightly negative"
    },
    "body": { "$value": "0em", "$type": "dimension" },
    "eyebrow": { "$value": "0.1em", "$type": "dimension", "$description": "Wide for uppercase" }
  },

  "lineHeight": {
    "display": {
      "$value": "1.05",
      "$type": "number",
      "$description": "Hero / display headline — 0.95–1.10 for Bodoni Moda theatrical line"
    },
    "subhead": { "$value": "1.25", "$type": "number", "$description": "Section / pull-quote" },
    "body": {
      "$value": "1.65",
      "$type": "number",
      "$description": "Body copy — 1.6–1.75 per Design Law 2"
    },
    "caption": { "$value": "1.33", "$type": "number", "$description": "12/16" }
  },

  "space": {
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": {
      "$value": "24px",
      "$type": "dimension",
      "$description": "The reference's margin-mobile"
    },
    "6": { "$value": "32px", "$type": "dimension", "$description": "The reference's gutter" },
    "7": { "$value": "48px", "$type": "dimension" },
    "8": {
      "$value": "64px",
      "$type": "dimension",
      "$description": "The reference's margin-desktop"
    },
    "9": { "$value": "96px", "$type": "dimension" },
    "10": {
      "$value": "120px",
      "$type": "dimension",
      "$description": "The reference's section-gap"
    },
    "11": { "$value": "160px", "$type": "dimension" }
  },

  "radius": {
    "none": { "$value": "0", "$type": "dimension" },
    "xs": { "$value": "2px", "$type": "dimension" },
    "sm": {
      "$value": "4px",
      "$type": "dimension",
      "$description": "The reference's DEFAULT border-radius"
    },
    "DEFAULT": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension", "$description": "The reference's lg" },
    "lg": { "$value": "12px", "$type": "dimension", "$description": "The reference's xl" },
    "xl": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "shadow": {
    "none": { "$value": "none", "$type": "shadow" },
    "xs": { "$value": "0 1px 2px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "sm": { "$value": "0 2px 8px rgba(0, 0, 0, 0.4)", "$type": "shadow" },
    "md": { "$value": "0 4px 16px rgba(0, 0, 0, 0.5)", "$type": "shadow" },
    "lg": { "$value": "0 8px 32px rgba(0, 0, 0, 0.6)", "$type": "shadow" },
    "colored": { "$value": "0 8px 24px rgba(233, 193, 118, 0.3)", "$type": "shadow" },
    "inner": { "$value": "inset 0 1px 3px rgba(0, 0, 0, 0.4)", "$type": "shadow" }
  },

  "duration": {
    "fast": { "$value": "200ms", "$type": "duration" },
    "base": { "$value": "300ms", "$type": "duration" },
    "slow": { "$value": "500ms", "$type": "duration" },
    "image": {
      "$value": "700ms",
      "$type": "duration",
      "$description": "Image hover scale (the reference)"
    },
    "page": { "$value": "600ms", "$type": "duration" }
  },

  "easing": {
    "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
    "decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
    "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" }
  },

  "container": {
    "max": {
      "$value": "1280px",
      "$type": "dimension",
      "$description": "The reference's container-max"
    },
    "gutter": { "$value": "32px", "$type": "dimension", "$description": "The reference's gutter" },
    "sectionGap": {
      "$value": "120px",
      "$type": "dimension",
      "$description": "The reference's section-gap"
    },
    "marginDesktop": {
      "$value": "64px",
      "$type": "dimension",
      "$description": "The reference's margin-desktop"
    },
    "marginMobile": {
      "$value": "24px",
      "$type": "dimension",
      "$description": "The reference's margin-mobile"
    }
  },

  "hero": {
    "minHeight": { "$value": "100vh", "$type": "dimension" },
    "minHeightMobile": { "$value": "85vh", "$type": "dimension" },
    "imageOpacity": {
      "$value": "0.5",
      "$type": "number",
      "$description": "Reference uses 50% image opacity"
    },
    "overlayFrom": { "$value": "{color.heroOverlayFrom.$value}", "$type": "color" },
    "overlayTo": { "$value": "{color.heroOverlayTo.$value}", "$type": "color" }
  },

  "css": {
    "$description": "The mapping from token name → CSS custom property.",

    "color": {
      "--color-primary-50": { "$value": "{color.primary.50.$value}", "$type": "color" },
      "--color-primary-100": { "$value": "{color.primary.100.$value}", "$type": "color" },
      "--color-primary-200": { "$value": "{color.primary.200.$value}", "$type": "color" },
      "--color-primary-300": { "$value": "{color.primary.300.$value}", "$type": "color" },
      "--color-primary-500": { "$value": "{color.primary.500.$value}", "$type": "color" },
      "--color-primary-700": { "$value": "{color.primary.700.$value}", "$type": "color" },
      "--color-primary-900": { "$value": "{color.primary.900.$value}", "$type": "color" },
      "--color-on-primary": { "$value": "{color.onPrimary.$value}", "$type": "color" },
      "--color-accent": { "$value": "{color.accent.$value}", "$type": "color" },
      "--color-on-accent": { "$value": "{color.onAccent.$value}", "$type": "color" },
      "--color-surface": { "$value": "{color.surface.$value}", "$type": "color" },
      "--color-surface-alt": { "$value": "{color.surfaceAlt.$value}", "$type": "color" },
      "--color-surface-card": { "$value": "{color.surfaceCard.$value}", "$type": "color" },
      "--color-surface-high": { "$value": "{color.surfaceHigh.$value}", "$type": "color" },
      "--color-surface-highest": { "$value": "{color.surfaceHighest.$value}", "$type": "color" },
      "--color-surface-dark": { "$value": "{color.surfaceDark.$value}", "$type": "color" },
      "--color-surface-bright": { "$value": "{color.surfaceBright.$value}", "$type": "color" },
      "--color-text": { "$value": "{color.text.$value}", "$type": "color" },
      "--color-text-muted": { "$value": "{color.textMuted.$value}", "$type": "color" },
      "--color-text-faint": { "$value": "{color.textFaint.$value}", "$type": "color" },
      "--color-border": { "$value": "{color.border.$value}", "$type": "color" },
      "--color-border-subtle": { "$value": "{color.borderSubtle.$value}", "$type": "color" },
      "--color-focus-ring": { "$value": "{color.focusRing.$value}", "$type": "color" },
      "--color-error": { "$value": "{color.error.$value}", "$type": "color" },
      "--color-success": { "$value": "{color.success.$value}", "$type": "color" }
