{
  "$schema": "https://lattice.app/schemas/theme-metadata.v1.json",
  "slug": "fine-dining",
  "name": "Fine Dining",
  "tagline": "An evening, set with care.",
  "category": "restaurants",
  "subcategory": "fine-dining",
  "tags": [
    "luxury",
    "serif",
    "tasting-menu",
    "reservations",
    "sommelier",
    "small-plate",
    "candle-lit"
