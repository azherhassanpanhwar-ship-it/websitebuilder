{
  "name": "lattice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,realtime -c blue,magenta \"pnpm --filter @lattice/web dev\" \"pnpm --filter @lattice/realtime dev\"",
    "dev:web": "pnpm --filter @lattice/web dev",
    "dev:realtime": "pnpm --filter @lattice/realtime dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @lattice/web build",
    "build:realtime": "pnpm --filter @lattice/realtime build",
    "start": "pnpm --filter @lattice/web start",
    "start:realtime": "pnpm --filter @lattice/realtime start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,css}\""
  },
  "dependencies": {
    "concurrently": "^9.0.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
