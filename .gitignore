# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testing ────────────────────────────────────────────────────────────────
/coverage

# ─── Next.js ────────────────────────────────────────────────────────────────
/.next/
/apps/**/.next/
/out/

# ─── Production ─────────────────────────────────────────────────────────────
/build
/dist

# ─── Misc ───────────────────────────────────────────────────────────────────
.DS_Store
*.pem
.turbo

# ─── Debug ──────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Env files (commit .env.example, never .env.local) ──────────────────────
.env
.env.local
.env.*.local
!.env.example

# ─── Vercel ─────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ─────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Playwright MCP cache (debug artifacts) ──────────────────────────────
.playwright-mcp/

# ─── Editor / OS ────────────────────────────────────────────────────────────
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
Thumbs.db
